<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/backBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@android:drawable/ic_menu_revert" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Anki Flashcards"
            android:textColor="@color/text_main"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/progressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1/10"
            android:textColor="@color/text_tertiary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Level Counts Display -->
    <LinearLayout
        android:id="@+id/levelCountsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/countLevel0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="New: 0"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/countLevel1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="Hard: 0"
            android:textColor="@color/red_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/countLevel2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Easy: 0"
            android:textColor="@color/blue_primary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Card Area -->
    <androidx.cardview.widget.CardView
        android:id="@+id/flashcard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomArea"
        android:layout_below="@id/levelCountsContainer"
        android:layout_margin="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/cardGerman"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="German Word"
                android:textColor="@color/text_main"
                android:textSize="36sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/divider"
                android:layout_width="80dp"
                android:layout_height="2dp"
                android:layout_marginVertical="24dp"
                android:background="@color/border"
                android:visibility="invisible" />

            <TextView
                android:id="@+id/cardMeaning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Meaning"
                android:textColor="@color/text_tertiary"
                android:textSize="24sp"
                android:visibility="invisible" />

            <TextView
                android:id="@+id/cardExample"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Example sentence goes here..."
                android:textColor="@color/text_placeholder"
                android:textSize="16sp"
                android:textStyle="italic"
                android:visibility="invisible" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom Interaction Area -->
    <LinearLayout
        android:id="@+id/bottomArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Initial Reveal Button -->
        <Button
            android:id="@+id/btnShowAnswer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_submit_button"
            android:text="SHOW ANSWER"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Anki Rating Buttons (Hidden initially) -->
        <LinearLayout
            android:id="@+id/ratingLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:weightSum="2">

            <Button
                android:id="@+id/btnAgain"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/red_primary"
                android:text="HARD"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnEasy"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:backgroundTint="@color/blue_primary"
                android:text="EASY"
                android:textColor="@color/white"
                android:textSize="12sp" />

        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
