<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:minHeight="match_parent">

        <!-- ── HEADER ── -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="0dp">

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_button_dark"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/text_secondary"
                android:contentDescription="Close" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/streak_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="-0.03"
                android:layout_marginStart="12dp" />

            <TextView
                android:id="@+id/tvActiveStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/active_status"
                android:textColor="@color/green_accent"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/bg_badge_active" />
        </LinearLayout>

        <!-- ── HERO CARD ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/heroCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_hero_card"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="24dp">

                <!-- Emoji -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌱"
                    android:textSize="30sp"
                    android:gravity="center"
                    android:lineSpacingExtra="0dp" />

                <!-- Big Streak Number -->
                <TextView
                    android:id="@+id/tvStreakNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="92sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_accent"
                    android:gravity="center"
                    android:lineSpacingExtra="0dp"
                    android:layout_marginTop="0dp" />

                <!-- DAY STREAK label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/streak_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:letterSpacing="0.25"
                    android:layout_marginTop="4dp" />

                <!-- Mini contribution strip -->
                <LinearLayout
                    android:id="@+id/contributionStrip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#21262D"
                    android:layout_marginTop="20dp" />

                <!-- Stats Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="18dp">

                    <!-- Best -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvBestVal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7d"
                            android:textColor="@color/green_accent"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_best"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:letterSpacing="0.05"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#21262D" />

                    <!-- Active -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvActiveVal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14d"
                            android:textColor="@color/green_accent"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_active"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:letterSpacing="0.05"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#21262D" />

                    <!-- Total -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvTotalVal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24d"
                            android:textColor="@color/green_accent"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_total"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:letterSpacing="0.05"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── ACTIVITY INSIGHTS SECTION ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="22dp">

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/activity_insights"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/this_month"
                    android:textColor="@color/green_accent"
                    android:textSize="11sp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:background="@drawable/bg_badge_month" />
            </LinearLayout>

            <!-- Calendar Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_calendar_card"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <!-- Month navigation -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageButton
                        android:id="@+id/btnPrevMonth"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_button_dark"
                        android:src="@android:drawable/ic_media_previous"
                        android:tint="@color/text_secondary"
                        android:contentDescription="Previous month"
                        android:padding="4dp" />

                    <TextView
                        android:id="@+id/tvMonthYear"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="March 2026"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <ImageButton
                        android:id="@+id/btnNextMonth"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_button_dark"
                        android:src="@android:drawable/ic_media_next"
                        android:tint="@color/text_secondary"
                        android:contentDescription="Next month"
                        android:padding="4dp" />
                </LinearLayout>

                <!-- Day-of-week headers -->
                <GridLayout
                    android:id="@+id/dayHeaders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="7"
                    android:layout_marginBottom="6dp" />

                <!-- Calendar grid -->
                <GridLayout
                    android:id="@+id/calendarGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="7" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#21262D"
                    android:layout_marginTop="12dp" />

                <!-- Legend -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end|center_vertical"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/less"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:layout_marginEnd="5dp" />

                    <LinearLayout
                        android:id="@+id/legendStrip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/more"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:layout_marginStart="5dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <!-- ── BOTTOM NAV ── -->
        <LinearLayout
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/bg_primary"
            android:paddingTop="14dp"
            android:paddingBottom="28dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <!-- Home -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:alpha="0.3" android:id="@+id/navHome">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⊞" android:textSize="16sp" android:textColor="@color/text_secondary" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/nav_home" android:textSize="10sp" android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" android:gravity="center"/>
            </LinearLayout>

            <!-- Add -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:alpha="0.3" android:id="@+id/navAdd">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="+" android:textSize="20sp" android:textColor="@color/text_secondary" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/nav_add" android:textSize="10sp" android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" android:gravity="center"/>
            </LinearLayout>

            <!-- Practice -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:alpha="0.3" android:id="@+id/navPractice">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✎" android:textSize="16sp" android:textColor="@color/text_secondary" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/nav_practice" android:textSize="10sp" android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" android:gravity="center"/>
            </LinearLayout>

            <!-- Learn -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:alpha="0.3" android:id="@+id/navLearn">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="▷" android:textSize="16sp" android:textColor="@color/text_secondary" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/nav_learn" android:textSize="10sp" android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" android:gravity="center"/>
            </LinearLayout>

            <!-- Streak (Active) -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:id="@+id/navStreak">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="◆" android:textSize="16sp" android:textColor="@color/green_accent" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/nav_streak" android:textSize="10sp" android:textColor="@color/green_accent"
                    android:textStyle="bold" android:layout_marginTop="4dp" android:gravity="center"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
